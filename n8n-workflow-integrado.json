      "parameters": {
        "jsCode": "// Preparar PDF base64 como binary para envio\nconst cadastroResult = $('Cadastrar Paciente').first().json;\nconst pdfBase64 = cadastroResult.pdf_base64;\nconst pdfFilename = cadastroResult.pdf_filename || 'Comprovante.pdf';\n\nif (!pdfBase64) {\n  throw new Error('PDF não foi gerado pela API');\n}\n\nconst binaryData = Buffer.from(pdfBase64, 'base64');\n\nreturn [{\n  json: {\n    filename: pdfFilename,\n    senha: cadastroResult.senha\n  },\n  binary: {\n    data: await this.helpers.prepareBinaryData(binaryData, pdfFilename, 'application/pdf')\n  }\n}];"
      },
