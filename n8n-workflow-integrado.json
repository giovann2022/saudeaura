    {
      "parameters": {
        "jsCode": "const output = $input.first().json.output;\nconst jsonMatch = output.match(/```json\\s*([\\s\\S]*?)\\s*```/);\nif (!jsonMatch) {\n  throw new Error('JSON não encontrado na resposta do AI Agent');\n}\nconst dadosPaciente = JSON.parse(jsonMatch[1]);\nconst partes = output.split('```');\nconst mensagemConfirmacao = (partes.length >= 3 ? partes[2].trim() : '') || 'Que Deus abençoe! 🙏 Seu cadastro foi realizado com sucesso!';\nconst EVENTO_ID = parseInt($env.EVENTO_ID_ATIVO) || 1;\nreturn [{\n  json: {\n    evento_id: EVENTO_ID,\n    dia_atendimento: dadosPaciente.dia_atendimento,\n    tipo_tratamento: dadosPaciente.tipo_tratamento,\n    nome: dadosPaciente.nome,\n    telefone: dadosPaciente.telefone,\n    nascimento: dadosPaciente.nascimento,\n    idade: dadosPaciente.idade,\n    rua: dadosPaciente.rua,\n    numero: dadosPaciente.numero,\n    complemento: dadosPaciente.complemento || null,\n    bairro: dadosPaciente.bairro,\n    cidade: dadosPaciente.cidade,\n    estado: dadosPaciente.estado,\n    queixa1: dadosPaciente.queixa1,\n    queixa2: dadosPaciente.queixa2 || null,\n    queixa3: dadosPaciente.queixa3 || null,\n    whatsapp_chat_id: $('Dados').first().json.chatId,\n    mensagem_confirmacao: mensagemConfirmacao\n  }\n}];"
      },
