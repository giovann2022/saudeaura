    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst item = items[0];\nconst binaryData = item.binary?.data;\nif (!binaryData) {\n  const mediaUrl = item.json?.mediaUrl || item.json?.url;\n  if (mediaUrl) {\n    return [{ json: { audioUrl: mediaUrl, chatId: $('Dados').first().json.chatId, session: $('Dados').first().json.session } }];\n  }\n  throw new Error('Áudio não encontrado no download');\n}\nconst base64Audio = binaryData.data;\nconst mimeType = binaryData.mimeType || 'audio/ogg';\nreturn [{ json: { audioBase64: base64Audio, mimeType: mimeType, chatId: $('Dados').first().json.chatId, session: $('Dados').first().json.session } }];"
      },
