      "parameters": {
        "jsCode": "const cadastroResult = $('Cadastrar Paciente').first().json;\nconst pdfBase64 = cadastroResult.pdf_base64;\nconst pdfFilename = cadastroResult.pdf_filename || 'Comprovante.pdf';\nif (!pdfBase64) {\n  throw new Error('PDF não foi gerado pela API');\n}\nconst binaryData = Buffer.from(pdfBase64, 'base64');\nreturn [{\n  json: { filename: pdfFilename, senha: cadastroResult.senha },\n  binary: { data: await this.helpers.prepareBinaryData(binaryData, pdfFilename, 'application/pdf') }\n}];"
      },
