    {
      "parameters": {
        "jsCode": "// Extrair o JSON do output do AI Agent\nconst output = $input.first().json.output;\n\n// Encontrar o bloco JSON na resposta\nconst jsonMatch = output.match(/```json\\s*([\\s\\S]*?)\\s*```/);\n\nif (!jsonMatch) {\n  throw new Error('JSON não encontrado na resposta do AI Agent');\n}\n\nconst dadosPaciente = JSON.parse(jsonMatch[1]);\n\n// Extrair a mensagem de confirmação (texto após o bloco JSON)\nconst partes = output.split('```');\nconst mensagemConfirmacao = (partes.length >= 3 ? partes[2].trim() : '') || 'Cadastro realizado com sucesso! Deus abençoe.';\n\n// ID do evento ativo - CONFIGURE AQUI ou use variável de ambiente no n8n\nconst EVENTO_ID = parseInt($env.EVENTO_ID_ATIVO) || 1;\n\nreturn [{\n  json: {\n    evento_id: EVENTO_ID,\n    dia_atendimento: dadosPaciente.dia_atendimento,\n    tipo_tratamento: dadosPaciente.tipo_tratamento,\n    nome: dadosPaciente.nome,\n    telefone: dadosPaciente.telefone,\n    nascimento: dadosPaciente.nascimento,\n    idade: dadosPaciente.idade,\n    rua: dadosPaciente.rua,\n    numero: dadosPaciente.numero,\n    complemento: dadosPaciente.complemento || null,\n    bairro: dadosPaciente.bairro,\n    cidade: dadosPaciente.cidade,\n    estado: dadosPaciente.estado,\n    queixa1: dadosPaciente.queixa1,\n    queixa2: dadosPaciente.queixa2 || null,\n    queixa3: dadosPaciente.queixa3 || null,\n    whatsapp_chat_id: $('Dados').first().json.chatId,\n    mensagem_confirmacao: mensagemConfirmacao\n  }\n}];"
      },
