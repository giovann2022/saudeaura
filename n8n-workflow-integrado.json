    {
      "parameters": {
        "jsCode": "// Pegar o áudio baixado como base64 e preparar para o Gemini\nconst items = $input.all();\nconst item = items[0];\n\n// O áudio vem como binary data do download\nconst binaryData = item.binary?.data;\nif (!binaryData) {\n  // Fallback: se não veio binary, talvez veio como JSON com base64\n  const mediaUrl = item.json?.mediaUrl || item.json?.url;\n  if (mediaUrl) {\n    return [{ json: { audioUrl: mediaUrl, chatId: $('Dados').first().json.chatId, session: $('Dados').first().json.session } }];\n  }\n  throw new Error('Áudio não encontrado no download');\n}\n\nconst base64Audio = binaryData.data;\nconst mimeType = binaryData.mimeType || 'audio/ogg';\n\nreturn [{\n  json: {\n    audioBase64: base64Audio,\n    mimeType: mimeType,\n    chatId: $('Dados').first().json.chatId,\n    session: $('Dados').first().json.session\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 100],
      "id": "code-prep-audio-01",
      "name": "Preparar Audio"
